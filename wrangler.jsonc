{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "canvas-pro",
  "compatibility_date": "2026-07-11",
  "compatibility_flags": ["nodejs_compat"],
  "main": "src/server.ts",
  "observability": {
    "enabled": true,
  },
  "durable_objects": {
    "bindings": [
      {
        "name": "CanvasRoom",
        "class_name": "CanvasRoom",
      },
    ],
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["CanvasRoom"],
    },
  ],
}
