{
  "name": "canvas-pro",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3000",
    "generate-routes": "tsr generate",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint",
    "format": "prettier --write . && eslint --fix",
    "check": "prettier --check .",
    "cf-typegen": "wrangler types",
    "db:generate": "drizzle-kit generate",
    "db:check": "drizzle-kit check",
    "db:migrate:local": "wrangler d1 migrations apply canvas-pro-auth --local",
    "db:migrate:remote": "wrangler d1 migrations apply canvas-pro-auth --remote",
    "db:create": "wrangler d1 create canvas-pro-auth --binding AUTH_DB --update-config",
    "validate": "bun run check && bun run lint && bun run test && bun run typecheck && bun run db:check && bun run build",
    "deploy": "bun run validate && wrangler deploy"
  },
  "dependencies": {
    "@better-auth/drizzle-adapter": "^1.6.23",
    "@cloudflare/vite-plugin": "^1.26.0",
    "@fontsource-variable/archivo": "^5.2.8",
    "@fontsource-variable/newsreader": "^5.2.10",
    "@fontsource/archivo": "^5.2.8",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/newsreader": "^5.2.10",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-devtools": "latest",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-devtools": "latest",
    "@tanstack/react-router-ssr-query": "latest",
    "@tanstack/react-start": "latest",
    "@tanstack/router-plugin": "^1.132.0",
    "better-auth": "^1.6.23",
    "cf-workers-og": "^3.0.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^0.545.0",
    "partyserver": "^0.5.8",
    "partysocket": "^1.3.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwindcss": "^4.1.18",
    "y-partyserver": "^2.2.0",
    "yjs": "^13.6.31",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/devtools-vite": "latest",
    "@tanstack/eslint-config": "latest",
    "@tanstack/router-cli": "^1.132.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.20.0",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.0",
    "vitest": "^4.1.5",
    "wrangler": "^4.70.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  }
}
